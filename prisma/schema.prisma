// Prisma 7 schema (datasource URL configured in prisma.config.ts)
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERACIONAL
}

enum OrdemServicoStatus {
  EM_ANDAMENTO
  AGUARDANDO_APROVACAO
  AGUARDANDO_RETIRADA
  FINALIZADO
  ARQUIVADO
}

enum TipoPagamento {
  CARTAO
  PIX
  DINHEIRO
}

enum VendaStatus {
  EM_ANDAMENTO
  FINALIZADA
  CANCELADA
}

model Empresa {
  id              String   @id @default(cuid())
  nome            String
  nomeResponsavel String
  ativa           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  usuarios  Usuario[]
  produtos  Produto[]
  clientes  Cliente[]
  ordens    OrdemServico[]
  vendas    Venda[]
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senhaHash String
  telefone  String?
  role      Role     @default(OPERACIONAL)
  ativo     Boolean  @default(true)
  empresaId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa     Empresa                 @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  ordens      OrdemServicoUsuario[]
  vendas      Venda[]
  statusLogs  OrdemServicoStatusLog[]

  @@index([empresaId])
}

model Produto {
  id        String   @id @default(cuid())
  nome      String
  preco     Decimal  @db.Decimal(12, 2)
  codigo    String?
  empresaId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa    Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  ordens     OrdemServicoProduto[]
  vendaItens VendaItem[]

  @@unique([empresaId, codigo])
  @@index([empresaId, nome])
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  documento String?
  telefone  String?
  endereco  String?
  email     String?
  empresaId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  ordens  OrdemServico[]

  @@index([empresaId, nome])
  @@index([empresaId, documento])
}

model OrdemServico {
  id          String             @id @default(cuid())
  nome        String
  descricao   String?
  status      OrdemServicoStatus @default(EM_ANDAMENTO)
  pago        Boolean            @default(false)
  clienteId   String
  empresaId   String
  deadlineAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  empresa    Empresa                 @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente    Cliente                 @relation(fields: [clienteId], references: [id])
  usuarios   OrdemServicoUsuario[]
  produtos   OrdemServicoProduto[]
  statusLogs OrdemServicoStatusLog[]

  @@index([empresaId, status])
  @@index([empresaId, deadlineAt])
}

model OrdemServicoUsuario {
  ordemServicoId String
  usuarioId      String
  assignedAt     DateTime @default(now())

  ordemServico OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  usuario      Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([ordemServicoId, usuarioId])
  @@index([usuarioId])
}

model OrdemServicoProduto {
  ordemServicoId String
  produtoId      String
  quantidade     Int    @default(1)

  ordemServico OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  produto      Produto      @relation(fields: [produtoId], references: [id])

  @@id([ordemServicoId, produtoId])
}

model OrdemServicoStatusLog {
  id              String              @id @default(cuid())
  ordemServicoId  String
  usuarioId       String?
  statusAnterior  OrdemServicoStatus?
  statusNovo      OrdemServicoStatus
  observacao      String?
  createdAt       DateTime            @default(now())

  ordemServico OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  usuario      Usuario?     @relation(fields: [usuarioId], references: [id])

  @@index([ordemServicoId])
}

model Venda {
  id            String        @id @default(cuid())
  empresaId     String
  usuarioId     String
  tipoPagamento TipoPagamento
  valorTotal    Decimal       @db.Decimal(12, 2)
  desconto      Decimal       @default(0) @db.Decimal(12, 2)
  valorFinal    Decimal       @db.Decimal(12, 2)
  status        VendaStatus   @default(EM_ANDAMENTO)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  cancelAt      DateTime?

  empresa Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario Usuario     @relation(fields: [usuarioId], references: [id])
  itens   VendaItem[]

  @@index([empresaId, createdAt])
  @@index([empresaId, status])
}

model VendaItem {
  id            String  @id @default(cuid())
  vendaId       String
  produtoId     String
  quantidade    Int
  precoUnitario Decimal @db.Decimal(12, 2)

  venda   Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id])

  @@index([vendaId])
}
