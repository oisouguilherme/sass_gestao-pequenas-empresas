# --- Server ---
NODE_ENV=development
PORT=3333
CORS_ORIGIN=http://localhost:5173,https://saas-gestao-frontend.vercel.app

# --- Database (PostgreSQL local) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_gestao?schema=public"

# --- JWT ---
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- App ---
APP_URL=http://localhost:5173

# --- SMTP (deixe vazio em DEV para usar Ethereal automático) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SaaS Gestão <no-reply@saasgestao.local>"
